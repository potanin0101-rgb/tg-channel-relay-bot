BOT_TOKEN=123456:replace_me
TELEGRAM_BOT_TOKEN=

# Optional: comma-separated user ids allowed to manage the bot in private chat.
# If empty, the first user who opens the bot in private becomes the owner.
ADMIN_USER_IDS=

# Polling timeout in seconds.
POLL_TIMEOUT_SEC=30

# Delay before flushing media groups (albums).
MEDIA_GROUP_FLUSH_MS=1500

# Random delay before each relay send to target channels.
MIN_RELAY_DELAY_MS=300
MAX_RELAY_DELAY_MS=500

# How many latest source posts to keep for /replay_last.
SOURCE_HISTORY_LIMIT=100
